{
  "brand_name": "Anthropic",
  "brand_identity": {
    "mission": "Building reliable, interpretable, and steerable AI systems.",
    "values": ["Safety", "Responsibility", "Research Excellence", "Transparency"],
    "positioning": "The frontier AI safety company building the most trustworthy AI systems.",
    "personality_traits": ["Thoughtful", "Rigorous", "Trustworthy", "Approachable"],
    "tagline": ""
  },
  "colors": {
    "primary": [
      {
        "name": "Dark",
        "hex": "#141413",
        "rgb": "20, 20, 19",
        "usage": "Primary text and dark backgrounds"
      },
      {
        "name": "Light",
        "hex": "#FAF9F5",
        "rgb": "250, 249, 245",
        "usage": "Light backgrounds and text on dark"
      }
    ],
    "secondary": [
      {
        "name": "Mid Gray",
        "hex": "#B0AEA5",
        "rgb": "176, 174, 165",
        "usage": "Secondary elements"
      },
      {
        "name": "Light Gray",
        "hex": "#E8E6DC",
        "rgb": "232, 230, 220",
        "usage": "Subtle backgrounds"
      }
    ],
    "accent": [
      {
        "name": "Orange",
        "hex": "#D97757",
        "rgb": "217, 119, 87",
        "usage": "Primary accent — CTA buttons, highlights"
      },
      {
        "name": "Blue",
        "hex": "#6A9BCC",
        "rgb": "106, 155, 204",
        "usage": "Secondary accent"
      },
      {
        "name": "Green",
        "hex": "#788C5D",
        "rgb": "120, 140, 93",
        "usage": "Tertiary accent"
      }
    ],
    "neutral": [
      {"name": "White", "hex": "#FFFFFF", "usage": "Pure white for specific uses"},
      {"name": "Dark", "hex": "#141413", "usage": "Primary body text"}
    ]
  },
  "typography": {
    "heading_font": {
      "family": "Poppins",
      "fallback": "Arial, Helvetica, sans-serif",
      "weights": ["600", "700"],
      "source": "Google Fonts"
    },
    "body_font": {
      "family": "Lora",
      "fallback": "Georgia, serif",
      "weights": ["400", "500", "600"],
      "line_height": "1.6",
      "source": "Google Fonts"
    },
    "scale": {
      "h1": {"size": "48px", "weight": "700", "line_height": "1.2"},
      "h2": {"size": "36px", "weight": "600", "line_height": "1.25"},
      "h3": {"size": "28px", "weight": "600", "line_height": "1.3"},
      "body": {"size": "16px", "weight": "400", "line_height": "1.6"},
      "caption": {"size": "12px", "weight": "500", "line_height": "1.4"}
    }
  },
  "logo": {
    "variants": {
      "full_color": {
        "description": "Anthropic wordmark — dark on light backgrounds",
        "background_constraint": "Use on light or white backgrounds"
      },
      "reversed": {
        "description": "White wordmark for dark backgrounds",
        "background_constraint": "Use on dark backgrounds"
      }
    },
    "clear_space": {
      "unit": "height of the 'A' in the wordmark",
      "minimum": "1x on all sides"
    },
    "minimum_size": {
      "digital": "40px height",
      "print": "12mm height"
    },
    "placement": {
      "preferred_positions": ["top-left", "bottom-center"],
      "presentation_position": "bottom-right"
    },
    "dont_rules": [
      "Never stretch or distort the wordmark",
      "Never add effects (shadows, outlines, glows)",
      "Never recolor outside dark/white variants",
      "Never place on busy backgrounds without a container"
    ]
  },
  "imagery": {
    "photography": {
      "style": "Clean, warm, natural lighting. Thoughtful compositions with negative space.",
      "subjects": ["Technology in human context", "Diverse teams collaborating", "Abstract patterns"],
      "avoid": ["Sci-fi cliches", "Stock photo cliches", "Overly futuristic imagery"],
      "color_treatment": "Warm, slightly desaturated, consistent with brand warm neutrals"
    }
  },
  "verbal_identity": {
    "tone_of_voice": {
      "personality": ["Thoughtful", "Rigorous", "Approachable", "Honest"],
      "we_are": ["Clear and direct", "Intellectually curious", "Grounded in evidence"],
      "we_are_not": ["Hype-driven", "Jargon-heavy", "Dismissive of concerns"],
      "examples": {
        "on_brand": "We're working to understand and mitigate the risks of advanced AI systems.",
        "off_brand": "Our revolutionary AI will disrupt every industry and change the world!"
      }
    },
    "writing_style": {
      "voice": "Active voice. Clear, precise language.",
      "sentence_length": "Moderate — mix of concise and explanatory.",
      "capitalization": "Sentence case for headlines",
      "punctuation": {
        "oxford_comma": true,
        "exclamation_marks": "Rarely"
      }
    },
    "terminology": {
      "preferred": {
        "AI systems": "Use instead of 'AI models' in general context",
        "people": "Use instead of 'users' when discussing societal impact"
      },
      "avoid": ["disrupt", "revolutionary", "game-changing"]
    },
    "key_messages": {
      "primary": "Building AI systems that are safe, beneficial, and understandable.",
      "supporting": [
        "Safety research is at the core of everything we do.",
        "We believe AI should be developed responsibly.",
        "Claude is designed to be helpful, harmless, and honest."
      ],
      "cta_library": ["Learn more", "Read our research", "Try Claude", "Contact us"]
    }
  },
  "deliverable_defaults": {
    "social_media": {
      "hashtag_style": "CamelCase",
      "brand_hashtag": "#Anthropic",
      "emoji_usage": "Minimal — professional context",
      "cta_every_post": false
    },
    "presentation": {
      "aspect_ratio": "16:9",
      "min_font_size": "18pt",
      "logo_position": "bottom-right"
    },
    "print": {
      "bleed": "3mm",
      "default_dpi": 300,
      "color_mode": "CMYK"
    }
  }
}
